# Dependencies
node_modules/
.pnpm-store/
prisma/
# Environment variables
.env
.env.local
.env.*.local

# Prisma
# Generated client (often rebuilt in CI/CD)
# node_modules/.prisma/ is covered by node_modules above
# But if you generate outside node_modules, exclude it:
prisma/generated/

# Database files (SQLite)
*.db
*.db-journal
*.sqlite
*.sqlite-journal
prisma/dev.db
prisma/dev.db-journal

# Migrations (optional - depends on your workflow)
# Some teams commit migrations, some don't
# Uncomment if you want to ignore them:
# prisma/migrations/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Build outputs
dist/
build/
.next/
out/

# Testing
coverage/
.nyc_output/